# Scenario definitions — step-based orchestration format.
#
# Each scenario has:
#   params:   form inputs (rendered in the UI)
#   triggers: how it can be started (manual/schedule/chain)
#   steps:    ordered list, each dispatched through a driver plugin
#
# Step `with` values support ${params.X} and ${step_id.field} references.
#
# Keep this file generic. Product-specific scenarios belong in ignored local
# overlays such as config/scenarios.local.yaml.

components:
  webapp:        {label: "Web application",       icon: "ti-code"}
  backend:       {label: "Backend service",       icon: "ti-server"}
  rpm-el7:       {label: "RPM (EL7-compatible)", icon: "ti-package"}
  rpm-modern:    {label: "RPM (modern Linux)",   icon: "ti-package"}
  windows-app:   {label: "Windows installer",    icon: "ti-brand-windows"}
  agent-windows: {label: "Windows agent",        icon: "ti-device-desktop"}
  stage:         {label: "Test environment",     icon: "ti-stack-2"}

scenarios:

  build-webapp:
    label: "Build web application"
    component: webapp
    icon: "ti-code"
    accent: blue
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version", type: string, required: true, default: "1.0.0"}
      - {name: release, label: "Release", type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,  label: "Branch",  type: string, required: true, default: "main"}
      - {name: debug,   label: "Debug", type: boolean, default: false}
    steps:
      - id: build
        spider: forgejo
        action: build
        with: {component: webapp, repo: example-webapp, workflow: build.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}

  build-backend:
    label: "Build backend service"
    component: backend
    icon: "ti-server"
    accent: purple
    # Access is imported on first boot. Admin always bypasses scenario ACLs.
    access:
      view: {match: all, roles: [developer], teams: [backend]}
      run:  {match: all, roles: [developer], teams: [backend]}
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version", type: string, required: true, default: "1.0.0"}
      - {name: release, label: "Release", type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,  label: "Branch",  type: string, required: true, default: "main"}
      - {name: debug,   label: "Debug", type: boolean, default: false}
    steps:
      - id: build
        spider: forgejo
        action: build
        with: {component: backend, repo: example-backend, workflow: build.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}

  build-rpm-el7:
    label: "Build RPM (EL7-compatible)"
    component: rpm-el7
    icon: "ti-package"
    accent: teal
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version", type: string, required: true, default: "1.0.0"}
      - {name: release, label: "Release", type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,  label: "Branch",  type: string, required: true, default: "main"}
      - {name: debug,   label: "Debug", type: boolean, default: false}
    steps:
      - id: build
        spider: forgejo
        action: build
        with: {component: rpm-el7, repo: example-rpm-app, workflow: build-el7.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}

  build-rpm-modern:
    label: "Build RPM (modern Linux)"
    component: rpm-modern
    icon: "ti-package"
    accent: teal
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version", type: string, required: true, default: "1.0.0"}
      - {name: release, label: "Release", type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,  label: "Branch",  type: string, required: true, default: "main"}
      - {name: debug,   label: "Debug", type: boolean, default: false}
    steps:
      - id: build
        spider: forgejo
        action: build
        with: {component: rpm-modern, repo: example-rpm-app, workflow: build-rpm-modern.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}

  build-windows-installer:
    label: "Build Windows installer"
    component: windows-app
    icon: "ti-brand-windows"
    accent: teal
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version", type: string, required: true, default: "1.0.0"}
      - {name: release, label: "Release", type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,  label: "Branch",  type: string, required: true, default: "main"}
      - {name: debug,   label: "Debug", type: boolean, default: false}
    steps:
      - id: build
        spider: forgejo
        action: build
        with: {component: windows-app, repo: example-windows-app, workflow: build-windows.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}

  build-windows-agent:
    label: "Build Windows agent"
    component: agent-windows
    icon: "ti-device-desktop"
    accent: teal
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version", type: string, required: true, default: "1.0.0"}
      - {name: upload,  label: "Upload artifact", type: choice, required: true, options: ["true", "false"]}
      - {name: branch,  label: "Branch", type: string, required: true, default: "main"}
    steps:
      - id: build
        spider: forgejo
        action: build
        with: {component: agent-windows, repo: example-agent, workflow: build-windows-agent.yml, version: "${params.version}", upload: "${params.upload}", branch: "${params.branch}"}

  update-stage:
    label: "Update test environment"
    component: stage
    icon: "ti-reload"
    accent: amber
    triggers: [{type: manual}]
    params:
      - {name: version, label: "Version",   type: string, required: true, default: "1.0.0"}
      - {name: release, label: "Release",   type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,  label: "Branch",    type: string, required: true, default: "main"}
      - {name: os,      label: "Target OS", type: choice, required: true, options: [el7, modern-linux, windows]}
      - {name: debug,   label: "Debug",     type: boolean, default: false}
      - {name: target,  label: "Target VM", type: string, required: true, default: "stage-01"}
    steps:
      - id: build-web
        spider: forgejo
        action: build
        with: {component: webapp, repo: example-webapp, workflow: build.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}
      - id: build-backend
        spider: forgejo
        action: build
        with: {component: backend, repo: example-backend, workflow: build.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}
      - id: deploy
        spider: ansible-local
        action: deploy
        with: {component: deploy-stage, target: "${params.target}", os: "${params.os}", version: "${params.version}", webapp: "${build-web.artifact}", backend: "${build-backend.artifact}"}

  create-stage:
    label: "Create test environment"
    component: stage
    icon: "ti-plus"
    accent: green
    triggers: [{type: manual}]
    params:
      - {name: version,    label: "Version",    type: string, required: true, default: "1.0.0"}
      - {name: release,    label: "Release",    type: choice, required: true, options: [stable, staging, dev]}
      - {name: branch,     label: "Branch",     type: string, required: true, default: "main"}
      - {name: os,         label: "OS",         type: choice, required: true, options: [el7, modern-linux, windows]}
      - {name: debug,      label: "Debug",      type: boolean, default: false}
      - {name: stage_name, label: "Environment name", type: string, required: true, default: "test-stage"}
    steps:
      - id: build-web
        spider: forgejo
        action: build
        with: {component: webapp, repo: example-webapp, workflow: build.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}
      - id: build-backend
        spider: forgejo
        action: build
        with: {component: backend, repo: example-backend, workflow: build.yml, version: "${params.version}", release: "${params.release}", branch: "${params.branch}", debug: "${params.debug}"}
      - id: vm
        spider: tofu-proxmox
        action: provision
        with: {name: "${params.stage_name}-${params.os}", os: "${params.os}"}
      - id: deploy
        spider: ansible-local
        action: deploy
        with: {component: deploy-stage, target: "${vm.ip}", os: "${vm.os}", conn: "${vm.conn}", version: "${params.version}", webapp: "${build-web.artifact}", backend: "${build-backend.artifact}"}
