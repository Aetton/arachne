# Arachne — Docker Compose
#
#   docker compose up -d
#
# On first boot an 'admin' user is seeded. Override the password:
#   ADMIN_PASSWORD=... docker compose up -d

services:
  arachne:
    build: .
    container_name: arachne
    restart: unless-stopped
    ports:
      - "8080:8000"
    env_file:
      - .env
    environment:
      DATABASE_URL: "postgresql+psycopg://arachne:${POSTGRES_PASSWORD}@db:5432/arachne"
      JWT_SECRET: "${JWT_SECRET}"
      ADMIN_PASSWORD: "${ADMIN_PASSWORD}"
      NEXUS_URL: "${NEXUS_URL:-https://nexus.example.internal}"
      ANSIBLE_PLAYBOOKS_DIR: /app/playbooks
      SCENARIOS_CONFIG: /app/config/scenarios.yaml
      SSL_CERT_FILE: /etc/ssl/certs/ca.crt
      REQUESTS_CA_BUNDLE: /etc/ssl/certs/ca.crt
    volumes:
      - ./config:/app/config:ro
      - ./playbooks:/app/playbooks:ro
      - ./certs/:/etc/ssl/certs/:ro
      # mount your ssh key if playbooks provision remote VMs
      # - ~/.ssh/arachne_id_ed25519:/root/.ssh/id_ed25519:ro
    depends_on:
      db:
        condition: service_healthy

  db:
    image: postgres:16-alpine
    container_name: arachne-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: arachne
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD}"
      POSTGRES_DB: arachne
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U arachne -d arachne"]
      interval: 5s
      timeout: 5s
      retries: 12
      start_period: 10s

  nats:
    image: nats:2-alpine
    container_name: arachne-nats
    profiles: ["nats"]
    restart: unless-stopped
    command: ["-js"]
    ports:
      - "4222:4222"

volumes:
  pgdata:
