# Copy to .env and adjust. docker compose reads it automatically.

# Runtime profile: dev (default), prod, or production.
ENV=dev

# Sign JWTs with this — MUST change in prod (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# Seeded admin password on first boot. Change immediately via the admin UI.
ADMIN_PASSWORD=change-me

# Artifact repository base URL (download links are built from this).
NEXUS_URL=https://nexus.example.internal

# Artifact upload creds — consumed by playbooks/workflows, not the portal itself.
# In production, pull these from a secret manager instead of hardcoding.
NEXUS_USER=
NEXUS_PASSWORD=

# Bus backend: inmemory (default, single process) or nats (multi-process).
BUS_BACKEND=inmemory
# NATS_URL=nats://nats:4222

# Forgejo/Gitea-compatible build backend + Arachne callback URL.
FORGEJO_URL=https://forgejo.example.internal
FORGEJO_TOKEN=
FORGEJO_OWNER=example

# External URL reachable from runners. Do not use localhost unless runners run on
# the same host as Arachne.
ARACHNE_URL=https://arachne.example.internal

# Keep TLS verification enabled. Add your CA to the container trust store instead
# of disabling verification in production.
FORGEJO_VERIFY_TLS=true
POSTGRES_PASSWORD=replace-with-a-long-random-password
