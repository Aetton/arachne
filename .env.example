# Copy to .env and adjust. docker compose reads it automatically.

# Sign JWTs with this — MUST change in prod (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# Seeded admin password on first boot. Change immediately via the admin UI.
ADMIN_PASSWORD=admin

# Nexus base URL (download links are built from this).
NEXUS_URL=https://nexus.redsoft.internal

# Nexus upload creds — consumed by the playbooks, not the portal itself.
# In prod, pull these from OpenBao instead of hardcoding.
NEXUS_USER=
NEXUS_PASSWORD=

# Bus backend: inmemory (default, single process) or nats (multi-process).
BUS_BACKEND=inmemory
# NATS_URL=nats://nats:4222

# Forgejo (build threads) + Arachne callback URL the runners report back to.
FORGEJO_URL=https://gitea.redsoft.internal
FORGEJO_TOKEN=
FORGEJO_OWNER=redsoft
ARACHNE_URL=https://arachne.redsoft.internal
